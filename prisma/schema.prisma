generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  carTitle  String
  createdAt DateTime @default(now())
}

model Car {
  id           Int      @id @default(autoincrement())
  title        String
  price        Int
  year         Int
  mileage      Int
  fuel         String
  transmission String
  description  String?
  imageUrl     String?
  createdAt    DateTime @default(now())
}
